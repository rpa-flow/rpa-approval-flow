    {
      "name": "Notas",
      "item": [
        {
          "name": "Listar notas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notas?status=AGUARDANDO_APROVACAO",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notas"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "AGUARDANDO_APROVACAO",
                  "description": "Opcional. Valores: AGUARDANDO_APROVACAO, APROVADO, PROCESSADO, EXPIRADA.",
                  "disabled": true
                },
                {
                  "key": "includeXml",
                  "value": "true",
                  "description": "Opcional. Retorna xmlOriginal quando true.",
                  "disabled": true
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Criar nota",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{xApiKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notas"
              ]
            },
            "description": "Envie `xml` para extração automática ou informe os campos manualmente (ex.: prestador/tomador/valores/datas).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroNota\": \"1001\",\n  \"codigoIdentificador\": \"12345678901234567890123456789012345678901234\",\n  \"fornecedorId\": \"{{supplierId}}\",\n  \"prestadorNome\": \"Fornecedor Exemplo\",\n  \"prestadorCnpj\": \"12345678000199\",\n  \"tomadorNome\": \"Empresa Tomadora\",\n  \"valorServico\": 1500.75,\n  \"valorIssqn\": 75.03,\n  \"dataEmissao\": \"2026-04-27T10:00:00.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Criar nota (via XML)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{xApiKey}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notas"
              ]
            },
            "description": "Exemplo de ingestão enviando XML NFSe no campo `xml`.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"xml\": \"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?><NFSE><infNFSe><ide><nNFSe>1001</nNFSe><cLocEmi>3550308</cLocEmi><cLocPrestacao>3550308</cLocPrestacao></ide><prest><CNPJ>12345678000199</CNPJ><xNome>Fornecedor Exemplo</xNome><email>financeiro@fornecedor.com</email></prest><tomador><CPFCNPJ>99887766000155</CPFCNPJ><xNome>Empresa Tomadora</xNome><email>fiscal@tomador.com</email></tomador><servico><vServ>1500.75</vServ><vISSQN>75.03</vISSQN><aliq>0.05</aliq></servico></infNFSe></NFSE>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Atualizar nota",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notas/{{invoiceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notas",
                "{{invoiceId}}"
              ],
              "query": [
                {
                  "key": "includeXml",
                  "value": "true",
                  "description": "Opcional. Retorna xmlOriginal quando true.",
                  "disabled": true
                }
              ]
            },
            "description": "Pode enviar campos parciais para atualizar a nota (ex.: numeroNota, status, processada, statusProcessamento, tentativasNotificacao, ultimoLembreteEm).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroNota\": \"1001-A\",\n  \"status\": \"APROVADO\",\n  \"processada\": false,\n  \"statusProcessamento\": \"PROCESSANDO\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
